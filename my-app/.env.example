# API 配置（至少配置一种）

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-api03-...

# OpenAI 兼容格式 API（支持 DeepSeek、Moonshot 等）
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1

# DeepSeek 示例
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.deepseek.com/v1

# Moonshot (Kimi) 示例
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.moonshot.cn/v1

# 模型配置
SETTING_MODEL=gpt-4-turbo
WRITING_MODEL=gpt-4-turbo

# 生成参数配置
MAX_TOKENS=4096
MEMORY_LEVEL=3

# 可选：第三方 Anthropic 代理
# ANTHROPIC_BASE_URL=https://your-anthropic-proxy.com
