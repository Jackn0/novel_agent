# API 配置（至少配置一种）

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-api03-...

# OpenAI 兼容格式 API（支持 DeepSeek、Moonshot 等）
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1

# DeepSeek 示例
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.deepseek.com/v1

# Moonshot (Kimi) 示例
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.moonshot.cn/v1

# 模型配置
SETTING_MODEL=gpt-4-turbo
WRITING_MODEL=gpt-4-turbo

# 生成参数配置
MAX_TOKENS=4096
MEMORY_LEVEL=3

# 可选：第三方 Anthropic 代理
# ANTHROPIC_BASE_URL=https://your-anthropic-proxy.com

# ============================================================
# TTS 语音合成服务配置（有声小说功能，至少配置一个）
# ============================================================

# 默认TTS服务 (elevenlabs, openai, aliyun, baidu, tencent, edge)
DEFAULT_TTS_SERVICE=edge

# --- ElevenLabs (国际顶级品质，需代理) ---
# ELEVENLABS_API_KEY=your_elevenlabs_api_key

# --- OpenAI TTS (情感丰富) ---
# OPENAI_TTS_API_KEY=your_openai_api_key

# --- 阿里云语音合成 CosyVoice (国内首选) ---
# ALIYUN_ACCESS_KEY_ID=your_access_key_id
# ALIYUN_ACCESS_KEY_SECRET=your_access_key_secret
# ALIYUN_TTS_APPKEY=your_appkey

# --- 百度智能云语音合成 (免费额度充足) ---
# BAIDU_TTS_API_KEY=your_api_key
# BAIDU_TTS_SECRET_KEY=your_secret_key

# --- 腾讯云语音合成 ---
# TENCENT_SECRET_ID=your_secret_id
# TENCENT_SECRET_KEY=your_secret_key

# 音频生成配置
MAX_CONCURRENT_AUDIO_REQUESTS=3
DEFAULT_AUDIO_PAUSE_MS=500
